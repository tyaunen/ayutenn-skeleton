{
    "name": "tyaunen/ayutenn-skeleton",
    "description": "ayutennフレームワークのプロジェクトテンプレート。composer create-projectでインストールして使用します。",
    "version": "1.0.0",
    "type": "project",
    "license": "CC-BY-1.0",
    "authors": [
        {
            "name": "minoru otyauke"
        }
    ],
    "require": {
        "php": ">=8.0",
        "tyaunen/ayutenn-core": "dev-main"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "ayutenn\\skeleton\\": "./"
        }
    },
    "minimum-stability": "dev",
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:tyaunen/ayutenn-core.git"
        }
    ],
    "scripts": {
        "post-create-project-cmd": [
            "@php -r \"copy('config/config.json.example', 'config/config.json');\"",
            "@php scripts/download_assets.php"
        ],
        "post-install-cmd": [
            "@php scripts/download_assets.php"
        ]
    }
}
