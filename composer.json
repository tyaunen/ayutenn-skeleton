{
    "name": "tyaunen/ayutenn-skeleton",
    "description": "ayutennは、御茶請稔によるオレオレフレームワークです。第三者からの利用は想定していません。",
    "version": "1.0.0",
    "type": "library",
    "license": "CC-BY-1.0",
    "authors": [
        {
            "name": "minoru otyauke"
        }
    ],
    "require": {
        "php": ">=8.0",
        "tyaunen/ayutenn-core": "dev-main"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "ayutenn\\skeleton\\": "./"
        }
    },
    "minimum-stability": "dev",
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:tyaunen/ayunenn-core.git"
        }
    ]
}
